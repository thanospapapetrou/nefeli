<?xml version="1.0" encoding="UTF-8"?>
<persistence version="3.2" xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence https://jakarta.ee/xml/ns/persistence/persistence_3_2.xsd">
    <persistence-unit name="nefeli" transaction-type="RESOURCE_LOCAL">
        <class>io.github.thanospapapetrou.nefeli.db.Repository</class>
        <properties>
            <property name="jakarta.persistence.provider" value="org.hibernate.jpa.HibernatePersistenceProvider"/>
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://host.docker.internal:5432/nefeli"/>
            <property name="jakarta.persistence.jdbc.user" value="nefeli"/>
            <property name="jakarta.persistence.jdbc.password" value="n3f3l1"/>
            <property name="jakarta.persistence.schema-generation.database.action" value="create"/>
            <property name="jakarta.persistence.schema-generation.create-source" value="script"/>
            <property name="jakarta.persistence.schema-generation.create-script-source" value="./sql/schema.sql"/>
            <property name="jakarta.persistence.sql-load-script-source" value="./sql/data.sql"/>
        </properties>
    </persistence-unit>
</persistence>
